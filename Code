# =====================================
# MAIN
# =====================================

if __name__ == "__main__":

    token = get_access_token()

    if not token:
        exit()

    print("Access Token Generated")

    # Show all users in account
    get_users(token)

    # Verify host email
    user = get_user_by_email(token, HOST_EMAIL)

    if not user:
        print(
            "\nThe email is not found in your Zoom account.\n"
            "Copy the email from get_users() output."
        )
        exit()

    USER_ID = user["id"]

    print("\nUsing User ID:", USER_ID)

    meeting_id = create_meeting(token, USER_ID)

    if not meeting_id:
        exit()

    get_meetings(token, USER_ID)

    get_meeting_details(token, meeting_id)

    get_invitation(token, meeting_id)
